generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// Better Auth Core Tables
// ============================================================================

model User {
  id                   String   @id
  name                 String
  email                String   @unique
  emailVerified        Boolean  @default(false)
  image                String?
  platformRole         String   @default("user") // user, platform_admin
  language             String   @default("en") // en, id, ja, ko
  activeOrganizationId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  sessions                  Session[]
  accounts                  Account[]
  organizationMembers       Member[]
  organizationInvites       Invitation[]        @relation("inviterUser")
  coursesCreated            Course[]            @relation("courseCreatedByUser")
  lessonsCreated            Lesson[]            @relation("lessonCreatedByUser")
  enrollmentsCreatedBy      CourseEnrollment[]  @relation("enrolledByUser")
  classAnnouncementsCreated ClassAnnouncement[] @relation("classAnnouncementCreatedByUser")
  studentProfile            Student?

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ============================================================================
// Better Auth Organization Plugin Tables
// ============================================================================

model Organization {
  id           String   @id
  name         String
  slug         String   @unique
  logo         String?
  metadata     String?
  description  String?
  status       String   @default("active")
  customDomain String?  @unique
  createdAt    DateTime @default(now())

  members            Member[]
  invitations        Invitation[]
  students           Student[]
  studentCredentials StudentCredential[]
  studentSessions    StudentSession[]
  schoolClasses      SchoolClass[]
  courses            Course[]
  lessons            Lesson[]
  courseEnrollments  CourseEnrollment[]
  lessonProgress     LessonProgress[]

  @@index([slug])
  @@index([status])
  @@map("organization")
}

model Member {
  id             String   @id
  organizationId String
  userId         String
  role           String
  createdAt      DateTime @default(now())

  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions     MemberPermission[]
  homeroomClasses SchoolClass[]      @relation("ClassHomeroomTeacher")
  subjectClasses  ClassSubject[]

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([role])
  @@map("member")
}

model MemberPermission {
  id        String   @id @default(cuid())
  memberId  String
  resource  String
  action    String
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, resource, action])
  @@index([memberId])
  @@index([resource, action])
  @@map("member_permissions")
}

model Invitation {
  id             String   @id
  organizationId String
  email          String
  role           String
  status         String   @default("pending")
  expiresAt      DateTime
  inviterId      String
  teamId         String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation("inviterUser", fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@index([status])
  @@index([expiresAt])
  @@map("invitation")
}

// ============================================================================
// SchoolHub LMS Domain Tables
// ============================================================================

model Student {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?  @unique
  fullName       String   @db.VarChar(255)
  nisn           String?  @db.VarChar(50)
  email          String?
  phone          String?
  status         String   @default("active") // active, inactive, graduated, archived
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user             User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  classMemberships ClassStudent[]
  enrollments      CourseEnrollment[]
  progress         LessonProgress[]
  credential       StudentCredential?
  sessions         StudentSession[]

  @@unique([organizationId, nisn])
  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@map("students")
}

model StudentCredential {
  id                 String    @id @default(cuid())
  organizationId     String
  studentId          String    @unique
  username           String    @db.VarChar(80)
  passwordHash       String
  mustChangePassword Boolean   @default(true)
  failedLoginCount   Int       @default(0)
  lockedUntil        DateTime?
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([organizationId, username])
  @@index([organizationId])
  @@index([studentId])
  @@map("student_credentials")
}

model StudentSession {
  id             String   @id @default(cuid())
  token          String   @unique
  organizationId String
  studentId      String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([studentId])
  @@index([expiresAt])
  @@map("student_sessions")
}

model SchoolClass {
  id                String   @id @default(cuid())
  organizationId    String
  name              String   @db.VarChar(255)
  code              String   @db.VarChar(80)
  academicYear      String   @db.VarChar(32)
  capacity          Int      @default(30)
  status            String   @default("active") // active, archived
  homeroomTeacherId String?
  averageScore      Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  homeroomTeacher Member?             @relation("ClassHomeroomTeacher", fields: [homeroomTeacherId], references: [id], onDelete: SetNull)
  students        ClassStudent[]
  subjects        ClassSubject[]
  announcements   ClassAnnouncement[]

  @@unique([organizationId, code, academicYear])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([homeroomTeacherId])
  @@map("classes")
}

model ClassAnnouncement {
  id        String   @id @default(cuid())
  classId   String
  title     String   @db.VarChar(255)
  body      String   @db.Text
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class         SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  createdByUser User        @relation("classAnnouncementCreatedByUser", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([classId])
  @@index([createdBy])
  @@map("class_announcements")
}

model ClassStudent {
  id        String   @id @default(cuid())
  classId   String
  studentId String
  status    String   @default("active") // active, transferred, dropped
  joinedAt  DateTime @default(now())

  class   SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  student Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@index([classId])
  @@index([studentId])
  @@index([status])
  @@map("class_students")
}

model ClassSubject {
  id              String   @id @default(cuid())
  classId         String
  teacherMemberId String?
  subjectName     String   @db.VarChar(255)
  room            String?  @db.VarChar(80)
  dayOfWeek       String?  @db.VarChar(16)
  startTime       String?  @db.VarChar(8)
  endTime         String?  @db.VarChar(8)
  createdAt       DateTime @default(now())

  class         SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacherMember Member?     @relation(fields: [teacherMemberId], references: [id], onDelete: SetNull)

  @@index([classId])
  @@index([teacherMemberId])
  @@map("class_subjects")
}

model Course {
  id             String    @id @default(cuid())
  organizationId String
  title          String    @db.VarChar(255)
  description    String?   @db.Text
  thumbnailUrl   String?
  status         String    @default("draft") // draft, published, archived
  createdBy      String
  publishedAt    DateTime?
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser  User               @relation("courseCreatedByUser", fields: [createdBy], references: [id], onDelete: Cascade)
  lessons        Lesson[]
  enrollments    CourseEnrollment[]
  lessonProgress LessonProgress[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([createdBy])
  @@map("courses")
}

model Lesson {
  id             String   @id @default(cuid())
  organizationId String
  courseId       String
  title          String   @db.VarChar(255)
  content        String?  @db.Text
  videoUrl       String?
  orderIndex     Int
  status         String   @default("draft") // draft, published, archived
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  course        Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdByUser User             @relation("lessonCreatedByUser", fields: [createdBy], references: [id], onDelete: Cascade)
  progress      LessonProgress[]

  @@unique([courseId, orderIndex])
  @@index([organizationId])
  @@index([courseId])
  @@index([organizationId, courseId])
  @@map("lessons")
}

model CourseEnrollment {
  id             String    @id @default(cuid())
  organizationId String
  courseId       String
  studentId      String
  enrolledBy     String?
  status         String    @default("active") // active, completed, removed
  enrolledAt     DateTime  @default(now())
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  course         Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  enrolledByUser User?        @relation("enrolledByUser", fields: [enrolledBy], references: [id], onDelete: SetNull)

  @@unique([courseId, studentId])
  @@index([organizationId])
  @@index([courseId])
  @@index([studentId])
  @@index([status])
  @@map("course_enrollments")
}

model LessonProgress {
  id             String   @id @default(cuid())
  organizationId String
  courseId       String
  lessonId       String
  studentId      String
  completedAt    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson       Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([lessonId, studentId])
  @@index([organizationId])
  @@index([courseId])
  @@index([lessonId])
  @@index([studentId])
  @@map("lesson_progress")
}
