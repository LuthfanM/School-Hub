{
  "name": "schoolhub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "npm run dev -w @schoolhub/web",
    "dev:api": "npm run dev -w @schoolhub/api",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:push": "cd packages/database && prisma db push",
    "db:generate": "cd packages/database && prisma generate",
    "db:studio": "cd packages/database && prisma studio",
    "db:migrate": "cd packages/database && prisma migrate dev",
    "db:reset": "cd packages/database && prisma migrate reset --force",
    "seed:platform-admin": "npm run seed:platform-admin -w @schoolhub/api",
    "seed:platform-tenants": "npm run seed:platform-tenants -w @schoolhub/api"
  },
  "devDependencies": {
    "turbo": "^1.12.0",
    "typescript": "^6.0.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
