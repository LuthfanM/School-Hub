// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// User Profile (connects to Supabase Auth)
// ============================================================================
model Profile {
  id            String    @id @default(cuid())
  fullName      String?
  avatarUrl     String?
  email         String    @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  organizationsCreated     Organization[]          @relation("createdByUser")
  organizationMembers      OrganizationMember[]    @relation("memberUser")
  invitationsSent          Invitation[]            @relation("invitedByUser")
  invitationsReceived      Invitation[]            @relation("invitedUser")
  coursesCreated           Course[]                @relation("createdByUser")
  lessonsCreated           Lesson[]                @relation("createdByUser")
  enrollmentsCreatedBy     CourseEnrollment[]      @relation("enrolledByUser")
  courseEnrollments        CourseEnrollment[]      @relation("studentEnrollment")
  lessonProgress           LessonProgress[]        @relation("studentProgress")
  organizationMembershipsInvitedBy OrganizationMember[] @relation("invitedByMember")

  @@map("profiles")
}

// ============================================================================
// Organization (Tenant)
// ============================================================================
model Organization {
  id          String    @id @default(cuid())
  name        String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(50)
  description String?
  logoUrl     String?
  status      String    @default("active") // active, suspended, archived
  customDomain String?  @unique
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  createdByUser         Profile                @relation("createdByUser", fields: [createdBy], references: [id], onDelete: Cascade)
  members               OrganizationMember[]   @relation("orgMembers")
  invitations           Invitation[]           @relation("orgInvitations")
  courses               Course[]               @relation("orgCourses")
  lessons               Lesson[]               @relation("orgLessons")
  courseEnrollments     CourseEnrollment[]     @relation("orgEnrollments")
  lessonProgress        LessonProgress[]       @relation("orgProgress")

  @@index([slug])
  @@index([status])
  @@map("organizations")
}

// ============================================================================
// Organization Membership
// ============================================================================
model OrganizationMember {
  id              String    @id @default(cuid())
  organizationId  String
  userId          String
  role            String    // admin, teacher, student
  status          String    @default("active") // active, removed, pending
  invitedBy       String?
  joinedAt        DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  organization    Organization @relation("orgMembers", fields: [organizationId], references: [id], onDelete: Cascade)
  user            Profile       @relation("memberUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedByUser   Profile?      @relation("invitedByMember", fields: [invitedBy], references: [id], onDelete: SetNull)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([role])
  @@index([status])
  @@map("organization_members")
}

// ============================================================================
// Invitation
// ============================================================================
model Invitation {
  id              String    @id @default(cuid())
  organizationId  String
  email           String
  role            String    // admin, teacher, student
  tokenHash       String    @unique
  status          String    @default("pending") // pending, accepted, revoked, expired
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  invitedBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  organization    Organization @relation("orgInvitations", fields: [organizationId], references: [id], onDelete: Cascade)
  invitedByUser   Profile       @relation("invitedByUser", fields: [invitedBy], references: [id], onDelete: Cascade)
  acceptedByUser  Profile?      @relation("invitedUser", fields: [email], references: [email])

  @@index([organizationId])
  @@index([email])
  @@index([status])
  @@index([expiresAt])
  @@map("invitations")
}

// ============================================================================
// Course
// ============================================================================
model Course {
  id              String    @id @default(cuid())
  organizationId  String
  title           String    @db.VarChar(255)
  description     String?   @db.Text
  thumbnailUrl    String?
  status          String    @default("draft") // draft, published, archived
  createdBy       String
  publishedAt     DateTime?
  archivedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  organization    Organization         @relation("orgCourses", fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser   Profile               @relation("createdByUser", fields: [createdBy], references: [id], onDelete: Cascade)
  lessons         Lesson[]              @relation("courseLessons")
  enrollments     CourseEnrollment[]    @relation("courseEnrollments")
  lessonProgress  LessonProgress[]      @relation("courseProgress")

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([createdBy])
  @@map("courses")
}

// ============================================================================
// Lesson
// ============================================================================
model Lesson {
  id              String    @id @default(cuid())
  organizationId  String
  courseId        String
  title           String    @db.VarChar(255)
  content         String?   @db.Text
  videoUrl        String?
  orderIndex      Int
  status          String    @default("draft") // draft, published, archived
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  organization    Organization       @relation("orgLessons", fields: [organizationId], references: [id], onDelete: Cascade)
  course          Course              @relation("courseLessons", fields: [courseId], references: [id], onDelete: Cascade)
  createdByUser   Profile             @relation("createdByUser", fields: [createdBy], references: [id], onDelete: Cascade)
  progress        LessonProgress[]    @relation("lessonProgress")

  @@unique([courseId, orderIndex])
  @@index([organizationId])
  @@index([courseId])
  @@index([organizationId, courseId])
  @@map("lessons")
}

// ============================================================================
// Course Enrollment (Student enrollment in course)
// ============================================================================
model CourseEnrollment {
  id              String    @id @default(cuid())
  organizationId  String
  courseId        String
  studentId       String
  enrolledBy      String
  status          String    @default("active") // active, completed, removed
  enrolledAt      DateTime  @default(now())
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  organization    Organization   @relation("orgEnrollments", fields: [organizationId], references: [id], onDelete: Cascade)
  course          Course          @relation("courseEnrollments", fields: [courseId], references: [id], onDelete: Cascade)
  student         Profile         @relation("studentEnrollment", fields: [studentId], references: [id], onDelete: Cascade)
  enrolledByUser  Profile         @relation("enrolledByUser", fields: [enrolledBy], references: [id], onDelete: SetNull)

  @@unique([courseId, studentId])
  @@index([organizationId])
  @@index([courseId])
  @@index([studentId])
  @@index([status])
  @@map("course_enrollments")
}

// ============================================================================
// Lesson Progress (Student's lesson completion)
// ============================================================================
model LessonProgress {
  id              String    @id @default(cuid())
  organizationId  String
  courseId        String
  lessonId        String
  studentId       String
  completedAt     DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  organization    Organization   @relation("orgProgress", fields: [organizationId], references: [id], onDelete: Cascade)
  course          Course          @relation("courseProgress", fields: [courseId], references: [id], onDelete: Cascade)
  lesson          Lesson          @relation("lessonProgress", fields: [lessonId], references: [id], onDelete: Cascade)
  student         Profile         @relation("studentProgress", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([lessonId, studentId])
  @@index([organizationId])
  @@index([courseId])
  @@index([lessonId])
  @@index([studentId])
  @@map("lesson_progress")
}
